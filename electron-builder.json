{
  "appId": "com.kodar11.hackfreak",
  "productName": "HackFreak",
  "files": ["dist-electron", "dist-react"],
  "extraResources": ["dist-electron/preload.cjs", "src/assets/**"],
  "icon": "./desktopIcon.png",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "mac": {
    "target": "dmg",
    "artifactName": "HackFreak.${ext}"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "artifactName": "HackFreak.${ext}"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "artifactName": "HackFreak-Setup.${ext}"
  },
  "portable": {
    "artifactName": "HackFreak-Portable.${ext}"
  }
}
