{
  "steps": [
    { "type": "header", "text": "── AI CORE v1.4.0 — BEHAVIORAL ANALYSIS ──" },
    { "type": "delay", "duration": 600 },
    { "type": "system", "text": "[*] AI CORE ONLINE" },
    { "type": "log", "text": "    Model: Hacker-LLM v4.2" },
    { "type": "log", "text": "    Parameters: 175B" },
    { "type": "log", "text": "    Context window: 128K tokens" },
    { "type": "delay", "duration": 500 },
    { "type": "system", "text": "[*] Loading behavioral model for {{target}}..." },
    { "type": "log", "text": "    Subject: {{name}}" },
    { "type": "log", "text": "    Data sources: 14" },
    { "type": "log", "text": "    Time span: 180 days" },
    { "type": "delay", "duration": 600 },
    { "type": "system", "text": "[*] Processing communication patterns..." },
    { "type": "progress", "label": "Pattern analysis", "progressDuration": 3000 },
    { "type": "delay", "duration": 400 },
    { "type": "system", "text": "[+] Behavioral profile:" },
    { "type": "log", "text": "    Risk Score:         {{percent}}" },
    { "type": "log", "text": "    Activity Pattern:   Irregular" },
    { "type": "log", "text": "    Peak hours:         0200-0500 UTC" },
    { "type": "log", "text": "    Social connections: {{percent}} identified" },
    { "type": "delay", "duration": 500 },
    { "type": "system", "text": "[*] Cross-referencing known associates..." },
    { "type": "progress", "label": "Correlation", "progressDuration": 2500 },
    { "type": "delay", "duration": 400 },
    { "type": "system", "text": "[+] Intelligence summary for {{target}}:" },
    { "type": "log", "text": "    Email:      {{email}}" },
    { "type": "log", "text": "    Phone:      {{phone}}" },
    { "type": "log", "text": "    Location:   {{city}}" },
    { "type": "log", "text": "    Social:     {{instagram}}" },
    { "type": "log", "text": "    Education:  {{college}}" },
    { "type": "delay", "duration": 500 },
    { "type": "system", "text": "[*] Running risk assessment..." },
    { "type": "progress", "label": "Risk assessment", "progressDuration": 2000 },
    { "type": "delay", "duration": 400 },
    { "type": "log", "text": "    Confidence:    {{percent}}%" },
    { "type": "log", "text": "    Threat vector: {{hex}}-{{hex}}" },
    { "type": "log", "text": "    Report ID:     {{shortHash}}" },
    { "type": "delay", "duration": 1000 },
    { "type": "target_acquired" },
    { "type": "success", "text": "[✓] AI analysis of {{target}} complete." }
  ]
}
