{
  "steps": [
    { "type": "header", "text": "╔══════════════════════════════════════════╗" },
    { "type": "header", "text": "║        DECRYPTION ENGINE v5.2.0          ║" },
    { "type": "header", "text": "╚══════════════════════════════════════════╝" },
    { "type": "delay", "duration": 500 },
    { "type": "system", "text": "[*] Loading encrypted payload..." },
    { "type": "log", "text": "    File: intercepted_comm_042.enc" },
    { "type": "log", "text": "    Size: {{bytes}}" },
    { "type": "log", "text": "    Cipher: AES-256-GCM" },
    { "type": "delay", "duration": 600 },
    { "type": "system", "text": "[*] Analyzing encryption parameters..." },
    { "type": "log", "text": "    Key length:      256 bits" },
    { "type": "log", "text": "    IV:              {{shortHash}}" },
    { "type": "log", "text": "    Auth tag:        {{shortHash}}" },
    { "type": "log", "text": "    Salt:            {{shortHash}}" },
    { "type": "delay", "duration": 800 },
    { "type": "system", "text": "[*] Generating decryption keys..." },
    { "type": "log", "text": "    Running key derivation function (PBKDF2)..." },
    { "type": "log", "text": "    Iterations: 100,000" },
    { "type": "progress", "label": "Key derivation", "progressDuration": 2500 },
    { "type": "delay", "duration": 400 },
    { "type": "system", "text": "[*] Key generated: {{hash}}" },
    { "type": "delay", "duration": 300 },
    { "type": "system", "text": "[*] Decrypting data blocks..." },
    { "type": "delay", "duration": 200 },
    { "type": "log", "text": "    Block 0x0000: {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}}" },
    { "type": "log", "text": "    Block 0x0010: {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}}" },
    { "type": "log", "text": "    Block 0x0020: {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}}" },
    { "type": "log", "text": "    Block 0x0030: {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}}" },
    { "type": "log", "text": "    Block 0x0040: {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}} {{hex}}" },
    { "type": "progress", "label": "Decrypting", "progressDuration": 3500 },
    { "type": "delay", "duration": 400 },
    { "type": "system", "text": "[*] Verifying integrity..." },
    { "type": "log", "text": "    HMAC check:     PASSED" },
    { "type": "log", "text": "    Padding:        VALID" },
    { "type": "log", "text": "    Auth tag:       VERIFIED" },
    { "type": "delay", "duration": 300 },
    { "type": "system", "text": "[+] Decryption complete." },
    { "type": "log", "text": "    Blocks processed: 4,096" },
    { "type": "log", "text": "    Output size:      {{bytes}}" },
    { "type": "log", "text": "    Output hash:      {{hash}}" },
    { "type": "delay", "duration": 200 },
    { "type": "success", "text": "[✓] Payload decrypted successfully. Output saved to /intelligence/decrypted/" }
  ]
}
